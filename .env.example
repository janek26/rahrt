# Resend email delivery for the MCP contact_janek tool.
# Create an API key at https://resend.com/api-keys and verify the sending
# domain at https://resend.com/domains before using this in production.
RESEND_API_KEY=
RESEND_FROM_EMAIL="Janek Portfolio <mcp@rahrt.me>"
MCP_CONTACT_TO_EMAIL=hello@rahrt.me

# MCP transport. Leave MCP_TRANSPORT unset for local stdio clients.
# Uncomment these for Docker, Railway, or any hosted server environment.
# MCP_TRANSPORT=http
# PORT=8080
# MCP_HTTP_HOST=0.0.0.0
# MCP_HTTP_ENDPOINT=/mcp
# MCP_HEALTH_PATH=/health

# Comma-separated browser origins allowed to call the hosted HTTP endpoint.
# Non-browser MCP clients without an Origin header are still accepted.
MCP_ALLOWED_ORIGINS=https://rahrt.me
MCP_CORS_ORIGIN=https://rahrt.me

# Optional: require hosted HTTP clients to send this in the X-API-Key header.
MCP_API_KEY=
